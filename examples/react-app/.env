# Loaded in all modes. Base values + an expanded one (dotenv-expand).
VITE_APP_NAME=viteenv demo
VITE_API_BASE=https://api.example.com
VITE_API_URL=${VITE_API_BASE}/v1
VITE_PUBLIC_KEY=pk_default_000
VITE_FEATURE_FLAGS=basic

# Not VITE_-prefixed -> intentionally NOT exposed to the client (lens hides it).
SECRET_DB_PASSWORD=do-not-leak
